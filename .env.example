# docker-compose orchestration vars. Copy to .env and adjust. Never commit .env.
# For running services standalone outside Docker, see backend/.env.example
# and frontend/.env.example.

# ---- Database ----
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-in-real-env
POSTGRES_DB=inventory
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full async DSN used by the backend
DATABASE_URL=postgresql+asyncpg://app:change-me-in-real-env@postgres:5432/inventory

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Backend ----
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:5173

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-64-char-random-string
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# Seeded admin (development only)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-in-real-env

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
