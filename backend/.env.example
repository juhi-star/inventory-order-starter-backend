# Backend (FastAPI) — for running uvicorn standalone outside Docker.
# Copy to backend/.env and adjust. Never commit backend/.env.
# When running via `docker compose up`, the root .env file is used instead.

APP_ENV=development
APP_LOG_LEVEL=INFO
# For Render deployment, set to your Vercel frontend URL
APP_CORS_ORIGINS=http://localhost:5173

# Standalone dev points at host-mapped Postgres and Redis (5432, 6379 on localhost).
# Render provides a postgres:// URL; the app converts it automatically to postgresql+psycopg://
DATABASE_URL=postgresql+asyncpg://app:change-me-in-real-env@localhost:5432/inventory
REDIS_URL=redis://localhost:6379/0

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-64-char-random-string
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# Seeded admin (development only)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-in-real-env
